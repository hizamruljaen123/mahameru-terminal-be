server {
    listen 443 ssl;
    server_name terminal.asetpedia.online;

    root /root/project/mahameru-terminal-fe/dist;
    index index.html;

    ssl_certificate /etc/letsencrypt/live/terminal.asetpedia.online/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/terminal.asetpedia.online/privkey.pem; # managed by Certbot
    include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem; # managed by Certbot

    # Security Headers
    add_header Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' blob: unpkg.com cdn.jsdelivr.net cdnjs.cloudflare.com cdn.plot.ly code.jquery.com s3.tradingview.com *.tradingview.com; worker-src 'self' blob:; style-src 'self' 'unsafe-inline' unpkg.com fonts.googleapis.com cdnjs.cloudflare.com; img-src 'self' data: blob: https: unpkg.com cdn.jsdelivr.net flagcdn.com *.tile.openstreetmap.org *.openstreetmap.org *.basemaps.cartocdn.com basemaps.cartocdn.com https://basemaps.cartocdn.com server.arcgisonline.com; connect-src 'self' blob: https: wss: unpkg.com api.asetpedia.online *.api.asetpedia.online wss://api.asetpedia.online wss://*.api.asetpedia.online https://api.asetpedia.online https://*.asetpedia.online s3.tradingview.com *.tradingview.com *.basemaps.cartocdn.com basemaps.cartocdn.com https://basemaps.cartocdn.com server.arcgisonline.com api.open-meteo.com restcountries.com data.bmkg.go.id *.openfreemap.org http://localhost:8100 http://localhost:8170 http://localhost:8500 ws://localhost:* ws://127.0.0.1:*; font-src 'self' fonts.gstatic.com unpkg.com cdnjs.cloudflare.com; frame-src 'self' youtube.com *.youtube.com s3.tradingview.com sslecal2.investing.com *.tradingview.com *.kaspersky.com maps.google.com *.google.com *.vesselfinder.com vesselfinder.com https://www.vesselfinder.com *.tradingview-widget.com https://www.tradingview-widget.com; media-src 'self' blob: https:;" always;

    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains; preload" always;
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header Permissions-Policy "camera=(), microphone=(), geolocation=(self), display-capture=()" always;

    location / {
        try_files $uri $uri/ /index.html;
    }

    # Cache Control untuk static assets
    location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|otf)$ {
        expires 1y;
        add_header Cache-Control "public, no-transform";
    }

    # Gzip Compression
    gzip on;
    gzip_vary on;
    gzip_proxied any;
    gzip_comp_level 6;
    gzip_types text/plain text/css text/xml application/json application/javascript application/rss+xml image/svg+xml;
}

server {
    if ($host = terminal.asetpedia.online) {
        return 301 https://$host$request_uri;
    }

    listen 80;
    server_name terminal.asetpedia.online;
    return 404;
}
